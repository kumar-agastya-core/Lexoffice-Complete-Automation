FROM node:22-slim AS base
RUN npm install -g pnpm@10 --no-update-notifier \
    && apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

FROM base AS installer
WORKDIR /app
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY packages/lexware-client/package.json packages/lexware-client/
COPY packages/db/package.json             packages/db/
COPY packages/crypto/package.json         packages/crypto/
COPY apps/dashboard/package.json          apps/dashboard/
RUN pnpm install --frozen-lockfile --ignore-scripts

FROM installer AS builder
COPY packages/ packages/
COPY apps/dashboard/ apps/dashboard/
RUN pnpm --filter '@lexware/client' build \
    && pnpm --filter '@lexware/db' build \
    && pnpm --filter '@lexware/crypto' build
ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm --filter '@lexware/dashboard' build

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Next.js standalone output is self-contained
COPY --from=builder /app/apps/dashboard/.next/standalone ./
# Static assets and public dir served by Next.js
COPY --from=builder /app/apps/dashboard/.next/static     ./apps/dashboard/.next/static
COPY --from=builder /app/apps/dashboard/public           ./apps/dashboard/public

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD node -e "fetch('http://localhost:3000/api/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

# server.js is generated by Next.js standalone build
CMD ["node", "apps/dashboard/server.js"]
