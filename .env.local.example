# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT — copy to .env.local and fill in values
# Use this when running dashboard + worker locally (not in Docker)
# Postgres and Redis still run in Docker via: make dev-infra
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (connects to Docker postgres on localhost) ───────────────────────
POSTGRES_PASSWORD=local-dev-password
DATABASE_URL=postgresql://lexware:local-dev-password@localhost:5432/lexware

# ── Redis (connects to Docker redis on localhost) ─────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=sk-

# ── Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
MASTER_ENCRYPTION_KEY=

# ── Dashboard auth ────────────────────────────────────────────────────────────
DASHBOARD_SECRET=my-local-secret

# ── URLs (localhost for local dev) ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
WORKER_PUBLIC_URL=http://localhost:3001
WORKER_BASE_URL=http://localhost:3001

# ── Email (placeholder for local — use /upload for testing) ──────────────────
INBOUND_EMAIL_DOMAIN=localhost
POSTMARK_WEBHOOK_TOKEN=

# ── Lexware webhooks ──────────────────────────────────────────────────────────
LEXWARE_WEBHOOK_SECRET=

# ── Optional (leave blank to use fallbacks) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
LEXWARE_API_KEY=
