# ─────────────────────────────────────────────────────────────────────────────
# LEXWARE AUTOMATION — Environment Configuration
# Copy this file to .env.production and fill in all values.
# NEVER commit .env.production to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL password — choose any strong password (min 20 chars recommended)
POSTGRES_PASSWORD=change_me_to_a_strong_password

# Full connection URL — auto-constructed in docker-compose from the above.
# Override only if using an external managed database.
DATABASE_URL=postgresql://lexware:${POSTGRES_PASSWORD}@postgres:5432/lexware

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── AI APIs ───────────────────────────────────────────────────────────────────
# Anthropic API key — required for LLM document classification
# Get it at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-

# OpenAI API key — required for pgvector embeddings (semantic search)
# If omitted: classification examples are saved without embeddings (degraded search)
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte master key as 64 hex characters. Used to encrypt all Lexware API keys at rest.
# Generate once at deployment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: if this key is lost, all tenant API keys must be re-entered.
MASTER_ENCRYPTION_KEY=

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Bearer token that protects all dashboard API routes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SECRET=

# Public URL of the dashboard (no trailing slash)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Email Ingestion ───────────────────────────────────────────────────────────
# Domain used for tenant inbound email addresses.
# Tenants forward invoices to: their-slug@<INBOUND_EMAIL_DOMAIN>
# Requires: Postmark inbound stream → MX records → WORKER_PUBLIC_URL/webhook/inbound-email
INBOUND_EMAIL_DOMAIN=bills.yourdomain.com

# HMAC token for verifying Postmark inbound webhook requests.
# Found in: Postmark → Server → Message Streams → Inbound → Webhook
POSTMARK_WEBHOOK_TOKEN=

# HMAC secret for verifying Lexware event webhook requests (set when creating subscriptions)
LEXWARE_WEBHOOK_SECRET=

# Publicly accessible HTTPS URL of the worker service.
# Used for Postmark and Lexware webhook callback URLs.
# Must be reachable from the internet. Example: https://worker.yourdomain.com
WORKER_PUBLIC_URL=https://worker.yourdomain.com

# ── Single-tenant fallback ────────────────────────────────────────────────────
# Optional: Lexware API key used when no tenantId is specified.
# Leave empty when using multi-tenant onboarding (/onboarding).
# If set, bypasses the encrypted key storage for all requests.
LEXWARE_API_KEY=

# ── Tenant context (dashboard only, single-tenant mode) ──────────────────────
LEXWARE_TENANT_ID=default

# ── Supabase Auth (optional — leave unset to use DASHBOARD_SECRET fallback) ──
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
